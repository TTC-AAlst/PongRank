# Postgres password for ponguser
DB_PASSWORD=my-secret-pw

# Configuration for the Itenium nuget feed
Nuget_CustomFeedUserName=
Nuget_CustomFeedPassword=

# ntfy token for sync → Slack #apps notifications (write-only to the `apps` topic).
# In prod, Coolify injects it from SOPS (PONGRANK__PROD__NTFY_TOKEN). Empty = off.
NTFY_TOKEN=
